# ========================================
# 后端环境变量配置模板
# 复制本文件为 .env，并填入你的真实配置值
# ========================================

# DeepSeek API 密钥
# 获取方式：访问 https://platform.deepseek.com/ 注册并创建 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 数据库连接地址
# 格式：mysql+aiomysql://用户名:密码@主机地址:端口/数据库名
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/chinese_teacher

# Redis 连接地址
# 格式：redis://主机地址:端口/数据库编号
REDIS_URL=redis://localhost:6379/0

# 应用运行环境
# 可选值：development（开发）/ production（生产）
APP_ENV=development
